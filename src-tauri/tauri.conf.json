{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "graphene",
  "version": "0.1.0",
  "identifier": "com.graphene.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Graphene",
        "width": 1366,
        "height": 768,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "windowEffects": {
          "effects": [
            "acrylic"
          ]
        }
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
